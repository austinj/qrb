---
import { getCollection } from "astro:content";
import Show from "../components/Show.astro";

// Fetch and sort the collection by date in descending order
const allShows = (await getCollection("shows"))
  .filter((show) => show && show.data && show.data.title && show.id) // Filter out invalid or incomplete entries
  .sort((a, b) => {
    const dateA = new Date(a.data.pubDate);
    const dateB = new Date(b.data.pubDate);
    return dateB.getTime() - dateA.getTime(); // Most recent date first
  });

// Get the most recent show and the next three shows
const mostRecentShow = allShows[0];
const nextThreeShows = allShows.slice(1, 4);

// Pass the most recent show date (YYYY-MM-DD) to the client for dynamic show-status calculation
const lastShowDateStr = mostRecentShow ? mostRecentShow.data.pubDate.toISOString().slice(0, 10) : null;
---

<div class="container max-w-3xl mx-auto px-4 md:px-0">
  <p class="md:text-5xl text-4xl">The Quadraphonic Rock Block</p>
  <p>
    is a radio show on <a class="text-blue-500 hover:underline font-semibold" href="https://kucr.org/">KUCR</a>, the campus radio station for the University of California, Riverside. It's music, broadcast by <a class="text-blue-500 hover:underline font-semibold" href="https://ahjohnson.com/">me</a> every other Friday from 11 am to 12 pm Pacific.<strong id="show-status" data-last-show={lastShowDateStr}></strong></p>
  </p>

  <script>
    const el = document.getElementById('show-status');
    if (el && el.dataset.lastShow) {
      const parts = el.dataset.lastShow.split('-');
      const lastShowDate = new Date(+parts[0], +parts[1] - 1, +parts[2]);

      const today = new Date();
      today.setHours(0, 0, 0, 0);

      // Find the next show date: advance from the last show by 2 weeks at a time
      const nextShow = new Date(lastShowDate);
      while (nextShow <= today) {
        nextShow.setDate(nextShow.getDate() + 14);
      }
      // If last show is today, show today's date
      if (lastShowDate.getTime() === today.getTime()) {
        nextShow.setTime(today.getTime());
      }

      const formatted = nextShow.toLocaleDateString('en-US', {
        month: 'long', day: 'numeric', year: 'numeric'
      });
      el.textContent = ` The next show is on ${formatted}.`;
    }
  </script>

  <h2 class="mt-4 md:mt-8 md:text-2xl text-xl font-bold">Most Recent Show</h2>
  <ul class="list-disc md:pl-8 pl-6 space-y-1 md:text-xl text-base">
    <li class="mt-4">
      {mostRecentShow ? (
        <Show 
          url={mostRecentShow.data.spinitron && mostRecentShow.data.spinitron.trim() !== '' ? mostRecentShow.data.spinitron : '#'} 
          title={mostRecentShow.data.title} 
          tags={mostRecentShow.data.tags} 
        />
      ) : (
        <p>No recent shows available.</p>
      )}
    </li>
  </ul>

  <h2 class="mt-4 md:text-2xl text-xl font-bold">Last Few Shows</h2>
  <ul class="list-disc pl-8 space-y-1 md:text-xl text-base">
    {nextThreeShows.map((show) =>
      show && show.data && show.data.title ? (
        <li class="mt-4">
          <Show 
            url={show.data.spinitron && show.data.spinitron.trim() !== '' ? show.data.spinitron : '#'} 
            title={show.data.title} 
            tags={show.data.tags} 
          />
        </li>
      ) : null
    )}
  </ul>
</div>
